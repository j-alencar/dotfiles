{{- if ne .chezmoi.os "windows" }}
exit 0
{{- end }}

$ErrorActionPreference = "Stop"
$ProgressPreference = "SilentlyContinue"

$CHOCO_TIMEOUT = 600

function Install-Choco {
    param([string]$Package)
    Write-Host "Installing $Package..."
    try {
        choco install $Package --yes --limit-output --execution-timeout $CHOCO_TIMEOUT
    } catch {
        Write-Warning "Failed to install ${Package}: $_"
    }
}

function Install-Winget {
    param([string]$PackageId)
    Write-Host "Installing $PackageId via winget..."
    $ErrorActionPreference = "Continue"
    winget install --id $PackageId --silent --accept-package-agreements --accept-source-agreements *>$null
    $ErrorActionPreference = "Stop"
    if ($LASTEXITCODE -ne 0) {
        Write-Warning "Failed to install ${PackageId} via winget (exit $LASTEXITCODE)"
    }
}

function Test-Command {
    param([string]$Command)
    return [bool](Get-Command $Command -ErrorAction SilentlyContinue)
}

# -- Chocolatey bootstrap -----------------------------------------------------
if (-not (Test-Command "choco")) {
    Write-Host "Installing Chocolatey..."
    Set-ExecutionPolicy Bypass -Scope Process -Force
    [System.Net.ServicePointManager]::SecurityProtocol = [System.Net.ServicePointManager]::SecurityProtocol -bor 3072
    Invoke-Expression ((New-Object System.Net.WebClient).DownloadString('https://community.chocolatey.org/install.ps1'))
    $env:PATH = "$env:ALLUSERSPROFILE\chocolatey\bin;$env:PATH"
}

$CHOCO_PACKAGES = @(
    "msys2",
    "chezmoi",
    "wezterm",
    "starship",
    "yazi",
    "nerd-fonts-jetbrainsmono",
    "fastfetch"
)

foreach ($pkg in $CHOCO_PACKAGES) {
    Install-Choco $pkg
}

# -- zoxide (not on Chocolatey or winget silent-install) ----------------------
if (-not (Test-Command "zoxide")) {
    Write-Host "Installing zoxide from GitHub releases..."
    try {
        $release = (Invoke-RestMethod "https://api.github.com/repos/ajeetdsouza/zoxide/releases/latest").tag_name
        $url = "https://github.com/ajeetdsouza/zoxide/releases/download/$release/zoxide-$($release.TrimStart('v'))-x86_64-pc-windows-msvc.zip"
        $zip = "$env:TEMP\zoxide.zip"
        Invoke-WebRequest $url -OutFile $zip
        $extracted = "$env:TEMP\zoxide-extracted"
        Expand-Archive $zip -DestinationPath $extracted -Force
        $dest = "$env:USERPROFILE\.local\bin"
        New-Item -ItemType Directory -Force $dest | Out-Null
        Copy-Item "$extracted\zoxide.exe" "$dest\zoxide.exe" -Force
        Remove-Item $zip, $extracted -Recurse -Force -ErrorAction SilentlyContinue
        Write-Host "zoxide installed to $dest\zoxide.exe"
    } catch {
        Write-Warning "Failed to install zoxide: $_"
    }
} else {
    Write-Host "zoxide already installed, skipping."
}

# -- atuin (not on Chocolatey or winget silent-install) -----------------------
if (-not (Test-Command "atuin")) {
    Write-Host "Installing atuin from GitHub releases..."
    try {
        $release = (Invoke-RestMethod "https://api.github.com/repos/atuinsh/atuin/releases/latest").tag_name
        $url = "https://github.com/atuinsh/atuin/releases/download/$release/atuin-x86_64-pc-windows-msvc.zip"
        $zip = "$env:TEMP\atuin.zip"
        Invoke-WebRequest $url -OutFile $zip
        $extracted = "$env:TEMP\atuin-extracted"
        Expand-Archive $zip -DestinationPath $extracted -Force
        $dest = "$env:USERPROFILE\.local\bin"
        New-Item -ItemType Directory -Force $dest | Out-Null
        Copy-Item "$extracted\atuin.exe" "$dest\atuin.exe" -Force
        Remove-Item $zip, $extracted -Recurse -Force -ErrorAction SilentlyContinue
        Write-Host "atuin installed to $dest\atuin.exe"
    } catch {
        Write-Warning "Failed to install atuin: $_"
    }
} else {
    Write-Host "atuin already installed, skipping."
}

# -- Set HOME to %USERPROFILE% so MSYS2/zsh finds chezmoi-managed configs -----
$currentHome = [System.Environment]::GetEnvironmentVariable("HOME", "User")
if ($currentHome -ne $env:USERPROFILE) {
    Write-Host "Setting HOME=$env:USERPROFILE for MSYS2..."
    [System.Environment]::SetEnvironmentVariable("HOME", $env:USERPROFILE, "User")
}

# -- WSL npm global packages ------------------------------------------
wsl -- bash -lc "command -v npm &>/dev/null && npm install -g opencode tailwindcss 2>/dev/null || true"

# -- uv -----------------------------------------------------------------------
if (-not (Test-Command "uv")) {
    Write-Host "Installing uv..."
    try {
        Invoke-RestMethod https://astral.sh/uv/install.ps1 | Invoke-Expression
        $env:PATH = "$env:USERPROFILE\.local\bin;$env:PATH"
    } catch {
        Write-Warning "Failed to install uv: $_"
    }
}

$UV_TOOLS = @("ruff", "flake8", "httpie", "yt-dlp", "grip", "pre-commit", "tldr", "ty")

if (Test-Command "uv") {
    $ErrorActionPreference = "Continue"
    foreach ($tool in $UV_TOOLS) {
        Write-Host "Installing uv tool: $tool..."
        uv tool install --upgrade $tool *>$null
        if ($LASTEXITCODE -ne 0) {
            Write-Warning "Failed to install uv tool ${tool} (exit $LASTEXITCODE)"
        }
    }
    $ErrorActionPreference = "Stop"
} else {
    Write-Warning "uv not found in PATH - skipping uv tool installs. Rerun after uv is installed."
}

Write-Host "Done."
