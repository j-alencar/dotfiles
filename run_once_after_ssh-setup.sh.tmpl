#!/bin/bash
{{ if ne .chezmoi.os "linux" }}
exit 0
{{ end }}

set -euo pipefail

mkdir -p "$HOME/.ssh"
chmod 700 "$HOME/.ssh"

GH_KEY=""
AZURE_KEY=""

if command -v gh &>/dev/null && gh auth status &>/dev/null 2>&1; then
    HOSTNAME=$(uname -n)
    if [[ -f "$HOME/.ssh/gh.pub" ]]; then
        PUBKEY_B64=$(awk '{print $2}' "$HOME/.ssh/gh.pub")
        if gh ssh-key list 2>/dev/null | grep -qF "$PUBKEY_B64"; then
            GH_KEY="$HOME/.ssh/gh"
            echo "GitHub: key already registered — skipping."
        else
            gh ssh-key add "$HOME/.ssh/gh.pub" --title "$HOSTNAME"
            GH_KEY="$HOME/.ssh/gh"
            echo "GitHub: SSH key added."
        fi
    else
        ssh-keygen -t ed25519 -C "{{ .email }}" -f "$HOME/.ssh/gh" -N ""
        gh ssh-key add "$HOME/.ssh/gh.pub" --title "$HOSTNAME"
        GH_KEY="$HOME/.ssh/gh"
        echo "GitHub: SSH key generated and added."
    fi
else
    echo "GitHub: 'gh' not authenticated — run 'gh auth login' to set up GitHub SSH."
fi

AZDEVOPS_ORG=$(az devops configure --list 2>/dev/null | awk -F= '/^organization/{print $2}' | tr -d ' ' || true)

if [[ -z "$AZDEVOPS_ORG" ]] && [[ -t 0 ]]; then
    read -rp "Azure DevOps org URL (e.g. https://dev.azure.com/myorg), leave blank to skip: " AZDEVOPS_ORG
fi

if [[ -z "$AZDEVOPS_ORG" ]]; then
    echo "Azure DevOps: no org URL — skipping."
elif command -v az &>/dev/null; then
    if ! az account show &>/dev/null 2>&1; then
        echo "Azure: logging in..."
        az login --use-device-code --output none
    fi

    az devops configure --defaults organization="$AZDEVOPS_ORG" 2>/dev/null || true

    PUBKEY_FILE="${GH_KEY:-$HOME/.ssh/gh}.pub"
    if [[ -f "$PUBKEY_FILE" ]]; then
        PUBKEY=$(cat "$PUBKEY_FILE")
        PUBKEY_DATA="${PUBKEY%% *}"
        EXISTING=$(az devops security credentials list --org "$AZDEVOPS_ORG" --output json 2>/dev/null | \
            jq -r '.[].publicData' 2>/dev/null || true)
        if echo "$EXISTING" | grep -qF "$PUBKEY_DATA"; then
            echo "Azure DevOps: SSH key already registered — skipping."
            AZURE_KEY="${PUBKEY_FILE%.pub}"
        else
            az devops security credentials create \
                --org "$AZDEVOPS_ORG" \
                --public-key "$PUBKEY" \
                --output none 2>/dev/null && \
                echo "Azure DevOps: SSH key added." && AZURE_KEY="${PUBKEY_FILE%.pub}" || \
                echo "Azure DevOps: could not register key — add manually at ${AZDEVOPS_ORG}/_usersSettings/keys"
        fi
    fi
else
    echo "Azure DevOps: 'az' CLI not found."
fi

SSH_CONFIG="$HOME/.ssh/config"
touch "$SSH_CONFIG"
chmod 600 "$SSH_CONFIG"

if [[ -n "$GH_KEY" ]] && ! grep -q "Host github.com" "$SSH_CONFIG" 2>/dev/null; then
    cat >> "$SSH_CONFIG" << EOF

Host github.com
    IdentityFile $GH_KEY
    AddKeysToAgent yes
EOF
    echo "SSH config: added github.com entry."
fi

if [[ -n "$AZURE_KEY" ]] && ! grep -q "Host ssh.dev.azure.com" "$SSH_CONFIG" 2>/dev/null; then
    cat >> "$SSH_CONFIG" << EOF

Host ssh.dev.azure.com
    IdentityFile $AZURE_KEY
    AddKeysToAgent yes
EOF
    echo "SSH config: added ssh.dev.azure.com entry."
fi

echo "SSH setup complete."
