#!/bin/bash
# hash: {{ include "dot_config/firefox/user.js" | sha256sum }}
{{ if ne .chezmoi.os "linux" }}
exit 0
{{ end }}
set -euo pipefail

PROFILE_DIR=$(find "$HOME/.mozilla/firefox" -maxdepth 1 -name "*.default-release" -type d 2>/dev/null | head -1 || true)
if [[ -z "$PROFILE_DIR" ]]; then
    PROFILE_DIR=$(find "$HOME/.mozilla/firefox" -maxdepth 1 -name "*.default" -type d 2>/dev/null | head -1 || true)
fi

if [[ -z "${PROFILE_DIR:-}" ]]; then
    echo "No Firefox profile found - skipping user.js deployment."
    exit 0
fi

cp "$HOME/.config/firefox/user.js" "$PROFILE_DIR/user.js"
echo "Deployed user.js to $PROFILE_DIR"
