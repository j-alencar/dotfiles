#!/usr/bin/env zsh

export ZDOTDIR="$HOME"
export XDG_CONFIG_HOME="$HOME/.config"
export XDG_DATA_HOME="$HOME/.local/share"
export XDG_CACHE_HOME="$HOME/.cache"

export EDITOR="vim"
export VISUAL="$EDITOR"

typeset -U path
{{ if eq .chezmoi.os "windows" -}}
path=(
    "$HOME/.local/bin"
    "$HOME/dotfiles/bin"
    "/c/ProgramData/chocolatey/bin"
    "/c/msys64/usr/bin"
    "/c/msys64/mingw64/bin"
    $path
)
{{ else -}}
path=(
    "$HOME/.local/bin"
    "$HOME/.cargo/bin"
    $path
)
{{ end -}}
