#!/bin/bash
{{- $distro := "" }}
{{- if eq .chezmoi.os "linux" }}
{{-   $distro = .chezmoi.osRelease.id }}
{{- end }}
{{ if ne .chezmoi.os "linux" }}
exit 0
{{ end }}

set -euo pipefail

IS_WSL=false
[[ -f /proc/version ]] && grep -qi microsoft /proc/version && IS_WSL=true

COMMON_PACKAGES=(
    curl wget git vim htop btop tree jq tmux zsh rsync nano
    make ripgrep net-tools fzf
)

DESKTOP_PACKAGES=(
    dolphin pinta papirus-icon-theme kde-gtk-config flatpak
    firefox keepassxc rofi feh mpd chafa fastfetch direnv xclip
)

{{ if eq $distro "arch" }}
DISTRO_PACKAGES=(
    python python-pip go base-devel openssh p7zip redis
    rustup starship zoxide atuin azcopy ttf-jetbrains-mono-nerd
    wezterm lazygit lazydocker k9s nodejs npm cmake ffmpeg
    btop pv postgresql syncthing httpie eza
)
{{ else if or (eq $distro "ubuntu") (eq $distro "debian") }}
DISTRO_PACKAGES=(
    python3 python3-pip golang-go build-essential openssh-server p7zip-full redis-server
    fonts-jetbrains-mono nodejs npm cmake btop pv postgresql syncthing httpie eza
)
{{ else if eq $distro "ol" }}
DISTRO_PACKAGES=(
    python3 python3-pip golang git-core openssl-devel
    nodejs npm cmake postgresql syncthing chafa fastfetch xclip yazi
)
{{ else if eq $distro "fedora" }}
DISTRO_PACKAGES=(
    python3 python3-pip golang git-core openssl-devel
    nodejs22 nodejs22-npm cmake pv postgresql syncthing chafa fastfetch xclip
    vim-enhanced wget2 7zip valkey openssh-server
    eza atuin zoxide gh
)
{{ end }}

KDE_PACKAGES=(
    dolphin pinta papirus-icon-theme kde-gtk-config
)

{{ if eq $distro "arch" }}
AUR_PACKAGES=(
    dropbox
    openfortivpn
    kwin-karousel
    clipmenu
    azure-cli
    mise
    gruvbox-plus-icon-theme
    kdeplasma-themes-kde-gruvbox-git
    kde-gruvbox-git
    yazi
)
{{ end }}

SCRIPT_PACKAGES=(
    "uv:curl -LsSf https://astral.sh/uv/install.sh | sh"
)

if [[ "$IS_WSL" == "false" ]]; then
    SCRIPT_PACKAGES+=(
        "zed:curl -f https://zed.dev/install.sh | sh"
    )
fi

{{ if or (eq $distro "ubuntu") (eq $distro "debian") (eq $distro "ol") (eq $distro "fedora") }}
SCRIPT_PACKAGES+=(
    "rustup:curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y"
    "starship:curl -sS https://starship.rs/install.sh | sh -s -- --yes"
    "atuin:ATUIN_VER=\$(curl -s https://api.github.com/repos/atuinsh/atuin/releases/latest | jq -r '.tag_name') && curl -Lo /tmp/atuin.tar.gz \"https://github.com/atuinsh/atuin/releases/download/\${ATUIN_VER}/atuin-x86_64-unknown-linux-musl.tar.gz\" && tar xf /tmp/atuin.tar.gz -C /tmp && install /tmp/atuin-x86_64-unknown-linux-musl/atuin \$HOME/.local/bin/atuin && rm -rf /tmp/atuin* && atuin import auto 2>/dev/null || true"
    "zoxide:curl -sSfL https://raw.githubusercontent.com/ajeetdsouza/zoxide/main/install.sh | sh"
    "lazydocker:curl https://raw.githubusercontent.com/jesseduffield/lazydocker/master/scripts/install_update_linux.sh | bash"
)
{{ end }}

CARGO_PACKAGES=(du-dust worktrunk)

DESKTOP_CARGO_PACKAGES=(rmpc jless)

UV_TOOLS=(ruff flake8 httpie yt-dlp ansible grip pre-commit tldr dumb-init eg ty)

FLATPAK_PACKAGES=(
    "com.discordapp.Discord"
    "md.obsidian.Obsidian"
    "com.spotify.Client"
)

echo "WSL: $IS_WSL"

{{ if eq $distro "arch" }}
sudo pacman -Syu --noconfirm
sudo pacman -S --needed --noconfirm "${COMMON_PACKAGES[@]}" "${DISTRO_PACKAGES[@]}" || true

if [[ "$IS_WSL" == "false" ]]; then
    sudo pacman -S --needed --noconfirm "${DESKTOP_PACKAGES[@]}" "${KDE_PACKAGES[@]}" || true

    if ! command -v yay &>/dev/null; then
        sudo pacman -S --needed --noconfirm git base-devel
        YAYTMP="$(mktemp -d)"
        git clone https://aur.archlinux.org/yay.git "$YAYTMP"
        (cd "$YAYTMP" && makepkg -si --noconfirm)
        rm -rf "$YAYTMP"
    fi

    for pkg in "${AUR_PACKAGES[@]}"; do
        yay -S --needed --noconfirm "$pkg" || true
    done
fi
{{ else if or (eq $distro "ubuntu") (eq $distro "debian") }}
sudo apt-get update
sudo apt-get install -y "${COMMON_PACKAGES[@]}" "${DISTRO_PACKAGES[@]}" || true

if [[ "$IS_WSL" == "false" ]]; then
    sudo apt-get install -y "${DESKTOP_PACKAGES[@]}" "${KDE_PACKAGES[@]}" || true
fi

if ! command -v lazygit &>/dev/null; then
    LAZYGIT_VERSION=$(curl -s --max-time 30 "https://api.github.com/repos/jesseduffield/lazygit/releases/latest" | jq -r '.tag_name' | sed 's/^v//')
    if [[ -n "$LAZYGIT_VERSION" && "$LAZYGIT_VERSION" != "null" ]]; then
        {
            curl -Lo /tmp/lazygit.tar.gz --max-time 120 "https://github.com/jesseduffield/lazygit/releases/download/v${LAZYGIT_VERSION}/lazygit_${LAZYGIT_VERSION}_Linux_x86_64.tar.gz"
            tar xf /tmp/lazygit.tar.gz -C /tmp lazygit
            sudo install /tmp/lazygit /usr/local/bin
            rm -f /tmp/lazygit /tmp/lazygit.tar.gz
        } || echo "warn: failed to install lazygit"
    else
        echo "warn: could not determine lazygit version (API rate limit?)"
    fi
fi

if ! command -v wezterm &>/dev/null; then
    {
        curl -fsSL --max-time 30 https://apt.fury.io/wez/gpg.key | sudo gpg --yes --dearmor -o /usr/share/keyrings/wezterm-fury.gpg
        echo 'deb [signed-by=/usr/share/keyrings/wezterm-fury.gpg] https://apt.fury.io/wez/ * *' | sudo tee /etc/apt/sources.list.d/wezterm.list
        sudo apt-get update
        sudo apt-get install -y wezterm || true
    } || echo "warn: failed to install wezterm"
fi

if ! command -v k9s &>/dev/null; then
    K9S_VERSION=$(curl -s --max-time 30 "https://api.github.com/repos/derailed/k9s/releases/latest" | jq -r '.tag_name')
    if [[ -n "$K9S_VERSION" && "$K9S_VERSION" != "null" ]]; then
        {
            curl -Lo /tmp/k9s.deb --max-time 120 "https://github.com/derailed/k9s/releases/download/${K9S_VERSION}/k9s_linux_amd64.deb"
            sudo dpkg -i /tmp/k9s.deb || true
            rm -f /tmp/k9s.deb
        } || echo "warn: failed to install k9s"
    else
        echo "warn: could not determine k9s version (API rate limit?)"
    fi
fi

if ! command -v azcopy &>/dev/null; then
    {
        curl -Lo /tmp/azcopy.tar.gz --max-time 120 "https://aka.ms/downloadazcopy-v10-linux"
        tar xf /tmp/azcopy.tar.gz -C /tmp --strip-components=1
        sudo install /tmp/azcopy /usr/local/bin
        rm -f /tmp/azcopy /tmp/azcopy.tar.gz
    } || echo "warn: failed to install azcopy"
fi

if ! command -v mise &>/dev/null; then
    curl --max-time 60 https://mise.run | sh || echo "warn: failed to install mise"
fi
{{ else if eq $distro "ol" }}
sudo dnf install -y epel-release || true
sudo dnf install -y --skip-broken "${COMMON_PACKAGES[@]}" "${DISTRO_PACKAGES[@]}" || true

if [[ "$IS_WSL" == "false" ]]; then
    sudo dnf install -y --skip-broken "${DESKTOP_PACKAGES[@]}" || true
fi

if ! command -v lazygit &>/dev/null; then
    LAZYGIT_VERSION=$(curl -s --max-time 30 "https://api.github.com/repos/jesseduffield/lazygit/releases/latest" | jq -r '.tag_name' | sed 's/^v//')
    if [[ -n "$LAZYGIT_VERSION" && "$LAZYGIT_VERSION" != "null" ]]; then
        {
            curl -Lo /tmp/lazygit.tar.gz --max-time 120 "https://github.com/jesseduffield/lazygit/releases/download/v${LAZYGIT_VERSION}/lazygit_${LAZYGIT_VERSION}_Linux_x86_64.tar.gz"
            tar xf /tmp/lazygit.tar.gz -C /tmp lazygit
            sudo install /tmp/lazygit /usr/local/bin
            rm -f /tmp/lazygit /tmp/lazygit.tar.gz
        } || echo "warn: failed to install lazygit"
    else
        echo "warn: could not determine lazygit version (API rate limit?)"
    fi
fi

if ! command -v k9s &>/dev/null; then
    K9S_VERSION=$(curl -s --max-time 30 "https://api.github.com/repos/derailed/k9s/releases/latest" | jq -r '.tag_name')
    if [[ -n "$K9S_VERSION" && "$K9S_VERSION" != "null" ]]; then
        {
            curl -Lo /tmp/k9s.tar.gz --max-time 120 "https://github.com/derailed/k9s/releases/download/${K9S_VERSION}/k9s_Linux_amd64.tar.gz"
            tar xf /tmp/k9s.tar.gz -C /tmp k9s
            sudo install /tmp/k9s /usr/local/bin
            rm -f /tmp/k9s /tmp/k9s.tar.gz
        } || echo "warn: failed to install k9s"
    else
        echo "warn: could not determine k9s version (API rate limit?)"
    fi
fi

if ! command -v azcopy &>/dev/null; then
    {
        curl -Lo /tmp/azcopy.tar.gz --max-time 120 "https://aka.ms/downloadazcopy-v10-linux"
        tar xf /tmp/azcopy.tar.gz -C /tmp --strip-components=1
        sudo install /tmp/azcopy /usr/local/bin
        rm -f /tmp/azcopy /tmp/azcopy.tar.gz
    } || echo "warn: failed to install azcopy"
fi

if ! command -v eza &>/dev/null; then
    EZA_VERSION=$(curl -s --max-time 30 "https://api.github.com/repos/eza-community/eza/releases/latest" | jq -r '.tag_name')
    if [[ -n "$EZA_VERSION" && "$EZA_VERSION" != "null" ]]; then
        {
            curl -Lo /tmp/eza.tar.gz --max-time 120 "https://github.com/eza-community/eza/releases/download/${EZA_VERSION}/eza_x86_64-unknown-linux-musl.tar.gz"
            tar xf /tmp/eza.tar.gz -C /tmp
            sudo install /tmp/eza /usr/local/bin
            rm -f /tmp/eza /tmp/eza.tar.gz
        } || echo "warn: failed to install eza"
    else
        echo "warn: could not determine eza version (API rate limit?)"
    fi
fi

if ! command -v gh &>/dev/null; then
    {
        sudo dnf config-manager addrepo --from-repofile=https://cli.github.com/packages/rpm/gh-cli.repo
        sudo dnf install -y gh || true
    } || echo "warn: failed to install gh"
fi

if ! command -v mise &>/dev/null; then
    curl --max-time 60 https://mise.run | sh || echo "warn: failed to install mise"
fi
{{ else if eq $distro "fedora" }}
sudo dnf install -y --skip-broken "${COMMON_PACKAGES[@]}" "${DISTRO_PACKAGES[@]}" || true

if [[ "$IS_WSL" == "false" ]]; then
    sudo dnf install -y --skip-broken "${DESKTOP_PACKAGES[@]}" "${KDE_PACKAGES[@]}" || true
fi

if ! command -v lazygit &>/dev/null; then
    LAZYGIT_VERSION=$(curl -s --max-time 30 "https://api.github.com/repos/jesseduffield/lazygit/releases/latest" | jq -r '.tag_name' | sed 's/^v//')
    if [[ -n "$LAZYGIT_VERSION" && "$LAZYGIT_VERSION" != "null" ]]; then
        {
            curl -Lo /tmp/lazygit.tar.gz --max-time 120 "https://github.com/jesseduffield/lazygit/releases/download/v${LAZYGIT_VERSION}/lazygit_${LAZYGIT_VERSION}_Linux_x86_64.tar.gz"
            tar xf /tmp/lazygit.tar.gz -C /tmp lazygit
            sudo install /tmp/lazygit /usr/local/bin
            rm -f /tmp/lazygit /tmp/lazygit.tar.gz
        } || echo "warn: failed to install lazygit"
    else
        echo "warn: could not determine lazygit version (API rate limit?)"
    fi
fi

if ! command -v k9s &>/dev/null; then
    K9S_VERSION=$(curl -s --max-time 30 "https://api.github.com/repos/derailed/k9s/releases/latest" | jq -r '.tag_name')
    if [[ -n "$K9S_VERSION" && "$K9S_VERSION" != "null" ]]; then
        {
            curl -Lo /tmp/k9s.tar.gz --max-time 120 "https://github.com/derailed/k9s/releases/download/${K9S_VERSION}/k9s_Linux_amd64.tar.gz"
            tar xf /tmp/k9s.tar.gz -C /tmp k9s
            sudo install /tmp/k9s /usr/local/bin
            rm -f /tmp/k9s /tmp/k9s.tar.gz
        } || echo "warn: failed to install k9s"
    else
        echo "warn: could not determine k9s version (API rate limit?)"
    fi
fi

if ! command -v azcopy &>/dev/null; then
    {
        curl -Lo /tmp/azcopy.tar.gz --max-time 120 "https://aka.ms/downloadazcopy-v10-linux"
        tar xf /tmp/azcopy.tar.gz -C /tmp --strip-components=1
        sudo install /tmp/azcopy /usr/local/bin
        rm -f /tmp/azcopy /tmp/azcopy.tar.gz
    } || echo "warn: failed to install azcopy"
fi

if ! command -v mise &>/dev/null; then
    curl --max-time 60 https://mise.run | sh || echo "warn: failed to install mise"
fi
{{ end }}

if [[ "$IS_WSL" == "false" ]] && command -v flatpak &>/dev/null; then
    flatpak remote-add --if-not-exists flathub https://dl.flathub.org/repo/flathub.flatpakrepo || true
    for pkg in "${FLATPAK_PACKAGES[@]}"; do
        flatpak install -y flathub "$pkg" || true
    done
fi

source "$HOME/.cargo/env" 2>/dev/null || true
export NVM_DIR="$HOME/.nvm"
[[ -s "$NVM_DIR/nvm.sh" ]] && source "$NVM_DIR/nvm.sh"

for entry in "${SCRIPT_PACKAGES[@]}"; do
    cmd="${entry%%:*}"
    script="${entry#*:}"
    if ! command -v "$cmd" &>/dev/null; then
        echo "Installing $cmd..."
        eval "$script" || echo "Failed to install $cmd"
    fi
done

if command -v rustup &>/dev/null; then
    rustup default stable 2>/dev/null || true
fi

source "$HOME/.cargo/env" 2>/dev/null || true
if command -v cargo &>/dev/null; then
    for pkg in "${CARGO_PACKAGES[@]}"; do
        cargo install --locked "$pkg" || true
    done
    if [[ "$IS_WSL" == "false" ]]; then
        for pkg in "${DESKTOP_CARGO_PACKAGES[@]}"; do
            cargo install --locked "$pkg" || true
        done
    fi
fi

if ! command -v yazi &>/dev/null; then
    YAZI_VERSION=$(curl -s --max-time 30 "https://api.github.com/repos/sxyazi/yazi/releases/latest" | jq -r '.tag_name')
    if [[ -n "$YAZI_VERSION" && "$YAZI_VERSION" != "null" ]]; then
        {
            curl -Lo /tmp/yazi.tar.gz --max-time 120 "https://github.com/sxyazi/yazi/releases/download/${YAZI_VERSION}/yazi-x86_64-unknown-linux-gnu.tar.gz"
            tar xf /tmp/yazi.tar.gz -C /tmp
            install /tmp/yazi-x86_64-unknown-linux-gnu/yazi "$HOME/.local/bin/yazi"
            install /tmp/yazi-x86_64-unknown-linux-gnu/ya "$HOME/.local/bin/ya"
            rm -rf /tmp/yazi.tar.gz /tmp/yazi-x86_64-unknown-linux-gnu
        } || echo "warn: failed to install yazi"
    else
        echo "warn: could not determine yazi version (API rate limit?)"
    fi
fi

if command -v uv &>/dev/null; then
    for tool in "${UV_TOOLS[@]}"; do
        uv tool install "$tool" 2>/dev/null || true
    done
fi

if [[ "$SHELL" != */zsh ]]; then
    ZSH_PATH=$(command -v zsh 2>/dev/null || find /usr /bin -name zsh -type f 2>/dev/null | head -1)
    if [[ -n "$ZSH_PATH" ]]; then
        if command -v chsh &>/dev/null; then
            chsh -s "$ZSH_PATH"
        else
            sudo usermod -s "$ZSH_PATH" "$USER" 2>/dev/null || \
                echo "Could not set default shell to zsh — run: sudo usermod -s $ZSH_PATH $USER"
        fi
    else
        echo "zsh not found in PATH, skipping shell change"
    fi
fi

echo "Done."
