#!/bin/bash
{{ if ne .chezmoi.os "linux" }}
exit 0
{{ end }}

set -euo pipefail

export NVM_DIR="$HOME/.nvm"
[[ -s "$NVM_DIR/nvm.sh" ]] && source "$NVM_DIR/nvm.sh"

if command -v nvm &>/dev/null; then
    if ! nvm ls lts/* &>/dev/null; then
        nvm install --lts
    fi
    nvm alias default 'lts/*' &>/dev/null || true
    NPM="$(command -v npm 2>/dev/null || true)"
elif command -v mise &>/dev/null; then
    mise use --global node@lts
    NPM="$HOME/.local/share/mise/shims/npm"
else
    NPM="$(command -v npm 2>/dev/null || true)"
fi

if [[ -z "${NPM:-}" ]]; then
    echo "npm not found — skipping."
    exit 0
fi

for pkg in "@anthropic-ai/claude-code" "worktrunk"; do
    name="${pkg##*/}"
    if ! command -v "$name" &>/dev/null; then
        "$NPM" install -g "$pkg" 2>/dev/null || echo "Failed to install $pkg"
    fi
done
