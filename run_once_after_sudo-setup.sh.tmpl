#!/bin/bash
{{ if ne .chezmoi.os "linux" }}
exit 0
{{ end }}

set -euo pipefail

SUDOERS_FILE="/etc/sudoers.d/$USER"

# Already has NOPASSWD?
if sudo -n true 2>/dev/null; then
    echo "Passwordless sudo already active — skipping."
    exit 0
fi

if [[ -f "$SUDOERS_FILE" ]] && grep -q "NOPASSWD" "$SUDOERS_FILE" 2>/dev/null; then
    echo "NOPASSWD sudoers entry already exists — skipping."
    exit 0
fi

if [[ ! -t 0 ]]; then
    echo "Not a terminal — skipping passwordless sudo prompt."
    exit 0
fi

echo ""
read -rp "Allow passwordless sudo for '$USER'? [y/N] " REPLY
if [[ "${REPLY,,}" == "y" ]]; then
    echo "$USER ALL=(ALL) NOPASSWD: ALL" | sudo tee "$SUDOERS_FILE" > /dev/null
    sudo chmod 440 "$SUDOERS_FILE"
    echo "Passwordless sudo enabled."
else
    echo "Skipped."
fi
