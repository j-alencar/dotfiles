{{- if ne .chezmoi.os "windows" }}
exit 0
{{- end }}

$ErrorActionPreference = "Stop"

$dest = "$env:USERPROFILE\.local\bin"
New-Item -ItemType Directory -Force $dest | Out-Null

# Starship: choco installs to "Program Files" with no shim, path has spaces
# Copy to ~/.local/bin so it's reachable from MSYS2 without space issues
$starship = "C:\Program Files\starship\bin\starship.exe"
if (Test-Path $starship) {
    Copy-Item $starship "$dest\starship.exe" -Force
    Write-Host "Copied starship to $dest"
} else {
    Write-Warning "starship not found at $starship - skipping"
}
